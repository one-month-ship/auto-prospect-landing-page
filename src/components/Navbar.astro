---
import NavbarMobile from "./NavbarMobile.tsx";

const links = [
  { href: "#features", label: "Fonctionnalités" },
  { href: "#how-it-works", label: "Comment ça marche" },
  { href: "#pricing", label: "Tarifs" },
  { href: "#faq", label: "FAQ" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt="Auto-Prospect" class="h-8 rounded-full" />
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-text-secondary transition-colors hover:text-text"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="hidden md:block">
      <a
        href="#pricing"
        class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-bg transition-colors hover:bg-accent-hover"
      >
        Essai gratuit
      </a>
    </div>

    <!-- Mobile hamburger (React island) -->
    <div class="md:hidden">
      <NavbarMobile client:load links={links} />
    </div>
  </div>
</nav>
