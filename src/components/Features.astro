---
const features = [
  {
    icon: "🔍",
    title: "Recherche automatique",
    description: "Définissez vos filtres (marque, modèle, prix, kilométrage…) et Auto-Prospect scrute LeBonCoin pour vous.",
  },
  {
    icon: "⚡",
    title: "Détection temps réel",
    description: "Scan continu des nouvelles annonces. Soyez le premier à repérer les bonnes affaires.",
  },
  {
    icon: "📱",
    title: "Contact multicanal",
    description: "Contactez les vendeurs par message vocal automatique. SMS et WhatsApp arrivent bientôt.",
  },
  {
    icon: "📊",
    title: "Pipeline de vente",
    description: "CRM Kanban intégré pour suivre chaque prospect de la détection à la conversion.",
  },
  {
    icon: "✉️",
    title: "Templates de messages",
    description: "Créez et réutilisez vos messages types pour gagner encore plus de temps.",
  },
  {
    icon: "👥",
    title: "Travail en équipe",
    description: "Collaborez avec vos collègues, partagez les hunts et répartissez les prospects.",
  },
];
---

<section id="features" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="fade-up text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-accent">Fonctionnalités</span>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Tout ce qu'il vous faut pour prospecter efficacement</h2>
    </div>

    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="fade-up group rounded-2xl border border-border bg-card p-6 transition-all hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
          <span class="text-3xl">{f.icon}</span>
          <h3 class="mt-4 text-lg font-semibold">{f.title}</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
