---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CalendlyWidget from "../../components/CalendlyWidget.astro";
import SubPageCTA from "../../components/SubPageCTA.astro";
import "../../styles/global.css";

const title = "CRM automobile intégré : pipeline de vente Kanban — Auto-Prospect";
const description =
  "Un CRM pensé pour les revendeurs auto : pipeline Kanban de la détection d'annonce à l'achat du véhicule, suivi des relances, travail en équipe. Intégré à la prospection, sans outil externe.";

const faq = [
  {
    q: "Qu'est-ce que le pipeline de vente d'Auto-Prospect ?",
    a: "C'est un CRM Kanban intégré, conçu pour l'achat-revente automobile. Chaque vendeur contacté devient une carte que vous déplacez d'étape en étape : annonce détectée, vendeur contacté, en négociation, rendez-vous, véhicule acheté.",
  },
  {
    q: "Ai-je besoin d'un CRM externe en plus d'Auto-Prospect ?",
    a: "Non. Le pipeline est inclus dans l'abonnement et directement alimenté par la prospection : les annonces détectées et les vendeurs contactés y entrent automatiquement, sans saisie manuelle ni export.",
  },
  {
    q: "Puis-je travailler en équipe sur le pipeline ?",
    a: "Oui, le travail en équipe est inclus. Plusieurs collaborateurs peuvent suivre et traiter les prospects sur le même pipeline.",
  },
  {
    q: "Que m'apporte un CRM par rapport à des notes ou un tableur ?",
    a: "Sans suivi structuré, les relances s'oublient et les prospects se perdent — c'est l'une des principales causes de deals manqués chez les revendeurs. Le Kanban montre d'un coup d'œil où en est chaque négociation et ce qui doit être relancé.",
  },
];

const jsonLd = [
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: "https://landing-page.auto-prospect.fr/" },
      { "@type": "ListItem", position: 2, name: "Fonctionnalités", item: "https://landing-page.auto-prospect.fr/#features" },
      { "@type": "ListItem", position: 3, name: "CRM pipeline de vente", item: "https://landing-page.auto-prospect.fr/fonctionnalites/crm-pipeline-vente" },
    ],
  },
  {
    "@type": "Service",
    name: "CRM automobile intégré — pipeline de vente Kanban",
    provider: { "@type": "Organization", name: "Auto-Prospect" },
    description:
      "CRM Kanban intégré pour revendeurs automobiles : suivi des prospects de la détection d'annonce à l'achat du véhicule, travail en équipe inclus.",
    areaServed: "FR",
  },
  {
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <Navbar />
  <main class="pt-32">
    <section class="pb-12">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <span class="text-sm font-semibold uppercase tracking-widest text-accent">Fonctionnalité</span>
        <h1 class="mt-3 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
          Un <span class="bg-gradient-to-r from-accent to-amber-400 bg-clip-text text-transparent">CRM automobile</span> intégré à votre prospection
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary">
          Auto-Prospect intègre un pipeline de vente Kanban pensé pour l'achat-revente automobile : chaque
          vendeur contacté devient un prospect que vous suivez de la détection de l'annonce jusqu'à l'achat du
          véhicule. Aucun CRM externe, aucune ressaisie.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold sm:text-3xl">Le coût caché du suivi désorganisé</h2>
        <p class="mt-4 leading-relaxed text-text-secondary">
          La plupart des revendeurs suivent leurs prospects dans leur tête, sur des notes ou dans un tableur.
          Tant qu'il y a trois négociations en cours, ça tient. Dès qu'il y en a quinze, les relances
          s'oublient, les rendez-vous se chevauchent et des véhicules partent chez un concurrent simplement
          parce que personne n'a rappelé le vendeur au bon moment. Un prospect oublié, c'est une marge perdue.
        </p>
        <p class="mt-4 leading-relaxed text-text-secondary">
          Les CRM généralistes résolvent ce problème, mais ils sont conçus pour vendre des services, pas pour
          acheter des véhicules — et ils vivent en dehors de votre outil de prospection, avec des exports et de
          la saisie manuelle à la clé.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold sm:text-3xl">Un Kanban alimenté automatiquement</h2>
        <p class="mt-4 leading-relaxed text-text-secondary">
          Le pipeline d'Auto-Prospect est directement branché sur la
          <a href="/fonctionnalites/recherche-annonces-automatisee" class="text-accent hover:underline">détection d'annonces</a>
          et le <a href="/fonctionnalites/contact-vocal-automatique" class="text-accent hover:underline">contact automatique des vendeurs</a> :
          chaque annonce détectée et chaque vendeur contacté entrent dans le tableau sans aucune saisie. Vous
          déplacez ensuite les cartes au fil de la négociation — contacté, en discussion, rendez-vous,
          véhicule acheté — et vous voyez d'un coup d'œil ce qui doit être relancé.
        </p>
        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-accent">✓</span>
            <span class="text-text-secondary"><strong class="text-text">Vue Kanban</strong> — toutes vos négociations en cours, classées par étape.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-accent">✓</span>
            <span class="text-text-secondary"><strong class="text-text">Historique par prospect</strong> — l'annonce d'origine, les messages envoyés, vos notes.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-accent">✓</span>
            <span class="text-text-secondary"><strong class="text-text">Travail en équipe</strong> — plusieurs collaborateurs sur le même pipeline, inclus dans l'abonnement.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-accent">✓</span>
            <span class="text-text-secondary"><strong class="text-text">Zéro outil externe</strong> — pas d'export, pas de double saisie, pas d'abonnement CRM supplémentaire.</span>
          </li>
        </ul>
      </div>
    </section>

    <section class="py-12">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-center text-2xl font-bold sm:text-3xl">Questions fréquentes</h2>
        <div class="mt-10">
          {faq.map((f) => (
            <details class="group border-b border-border py-2">
              <summary class="flex cursor-pointer items-center justify-between py-3 text-sm font-medium sm:text-base [&::-webkit-details-marker]:hidden">
                {f.q}
                <span class="text-text-secondary transition-transform group-open:rotate-180">⌄</span>
              </summary>
              <p class="pb-4 text-sm leading-relaxed text-text-secondary">{f.a}</p>
            </details>
          ))}
        </div>
        <p class="mt-8 text-center text-sm text-text-secondary">
          Inclus dans l'abonnement à 69 € HT/mois — <a href="/tarifs" class="text-accent hover:underline">voir les tarifs</a>.
        </p>
      </div>
    </section>

    <SubPageCTA />
  </main>
  <Footer />
  <CalendlyWidget />
</Layout>
